# Steam API key — obtain from https://steamcommunity.com/dev/apikey (required)
STEAM_API_KEY=your-steam-api-key

# One or more Steam users in STEAMID64=Display Name format, comma-separated (required)
STEAM_USERS=76561198000000000=Roommate

# SMTP credentials for email digests (required)
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_TO=you@example.com

# Optional SMTP settings
SMTP_FROM=you@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# How often to poll Steam (seconds, default: 86400 = 24 hours)
SLEEP_INTERVAL=86400

# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL (default: WARNING)
LOG_LEVEL=WARNING

# Path to the SQLite database inside the container
DATABASE_PATH=/data/library-cache.db

# Delay between Steam app-details API calls (seconds, default: 1.5)
APPDETAILS_DELAY=1.5
